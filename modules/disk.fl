import sys;

fn get_disk_data() arr<string> {
    const disk = sys.disk_usage("/") ~> if_fail("Erro de I/O no Kernel");
    
    var fb = str_array();
    push(fb, ((disk["used"] ~> to_int()) / 1048576) ~> to_str());
    push(fb, ((disk["total"] ~> to_int()) / 1048576) ~> to_str());
    
    return fb;
}
