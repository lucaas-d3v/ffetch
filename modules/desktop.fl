import env;
import str;

fn get_de() string {
    const r = env.get("XDG_CURRENT_DESKTOP");

    if len(r) > 0 {
        return r;    
    }
    
    return "Unknow";
}

fn get_wm() string {
    const wm = env.get("XDG_CURRENT_DESKTOP");
    
    if wm == "XFCE" {
        return "xfwm4";
    }
    
    const session = env.get("XDG_SESSION_TYPE");
    if len(session) > 0 {
        return session;
    }
    
    return "Unknown";
}