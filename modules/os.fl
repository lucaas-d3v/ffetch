import str;
import fs;

fn get_os() string { 
    const content = fs.read_file("/etc/os-release") ~> fallback("") ~> to_str(); 
    const lines_r = content ~> str.split("\n"); 

    if len(lines_r) > 0 { 
        const parts = lines_r[0] ~> str.split("="); 
        if len(parts) > 1 { 
            return parts[1] ~> str.replace("\"", ""); 
        } 
    } 
    return "Unknown OS";
}